AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
KAME_BASE_URL=https://api.kameone.cl

# Clave que deben enviar los clientes en header X-API-Key (requerida en producción)
